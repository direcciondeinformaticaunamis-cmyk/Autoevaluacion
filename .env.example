# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Drive upload integration. Prefer refresh-token OAuth for production.
# The Google account/token must have permission to create files in the target folders.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"
GOOGLE_REFRESH_TOKEN="MY_GOOGLE_REFRESH_TOKEN"

# Optional short-lived token alternative. If present, the server uses it directly.
# GOOGLE_DRIVE_ACCESS_TOKEN="MY_TEMPORARY_ACCESS_TOKEN"

# Folder routing. More specific mappings win: indicator > criterion > dimension > root.
# Use Google Drive folder IDs, not full URLs.
DRIVE_ROOT_FOLDER_ID="MY_DEFAULT_FOLDER_ID"
DRIVE_FOLDER_BY_DIMENSION='{"1":"DIMENSION_1_FOLDER_ID","2":"DIMENSION_2_FOLDER_ID","3":"DIMENSION_3_FOLDER_ID"}'
DRIVE_FOLDER_BY_CRITERION='{"1.1":"CRITERION_1_1_FOLDER_ID","1.2":"CRITERION_1_2_FOLDER_ID","2.1":"CRITERION_2_1_FOLDER_ID"}'
DRIVE_FOLDER_BY_INDICATOR='{"1.1.a":"INDICATOR_1_1_A_FOLDER_ID"}'
